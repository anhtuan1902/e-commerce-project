# ===========================================
# CẤU HÌNH DATABASE - PostgreSQL (Mặc định)
# ===========================================
# Chỉ cần đổi DB_DIALECT để chuyển database

NODE_ENV=development
APP_URL=http://localhost:5000

DB_DIALECT=postgres
DB_PORT=5432
DB_NAME=ecommerce_store_one_db
DB_USER=ecommerce_user
DB_PASSWORD=190228aT
DB_HOST=localhost
DB_SSL=false

# ===========================================
# CẤU HÌNH DATABASE - MySQL (Nếu dùng MySQL)
# ===========================================
# Để dùng MySQL, đổi:
#   - DB_DIALECT=mysql
#   - DB_PORT=3306
#   - DB_HOST=mysql (nếu dùng Docker)
# MYSQL_PORT=3306

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=190228aT
REDIS_TTL=604800

# JWT
JWT_SECRET=190228aT
JWT_REFRESH_SECRET=123456789aT
ACCESS_TOKEN_TTL=1800
