# ===========================================
# DATABASE CONFIG
# ===========================================
# DB_DIALECT options: postgres | mysql | supabase
# Nếu chọn supabase, cần điền SUPABASE_DB_URL bên dưới
# DB_DIALECT=supabase
# SUPABASE_DB_URL=postgres://postgres:your_password@db.[PROJECT_REF].supabase.co:6543/postgres
# Nếu password chứa ký tự đặc biệt như @, hãy encode thành %40

DB_DIALECT=postgres

# Supabase connection string (chỉ cần khi DB_DIALECT=supabase)
# Lấy từ: Supabase Dashboard > Settings > Database > Connection String
# SUPABASE_DB_URL=postgres://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ===========================================
# PostgreSQL Local Config (khi DB_DIALECT=postgres)
# ===========================================

NODE_ENV=development
APP_URL=http://localhost:5000
DB_PORT=5432
DB_NAME=ecommerce_store_one_db
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_SSL=false

# ===========================================
# MySQL Config (khi DB_DIALECT=mysql)
# ===========================================
# DB_PORT=3306

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173

# Redis
# Với local dev: REDIS_HOST=localhost
# Với Docker Compose: REDIS_HOST=redis
# Hoặc dùng REDIS_URL nếu bạn có connection string Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=190228aT
REDIS_TTL=604800

# JWT
JWT_SECRET=190228aT
JWT_REFRESH_SECRET=123456789aT
ACCESS_TOKEN_TTL=1800

# ===========================================
# PAYMENT GATEWAY CONFIG
# ===========================================

# VNPay (https://sandbox.vnpayment.vn/)
# Đăng ký tài khoản sandbox: https://sandbox.vnpayment.vn/ merchaninfo
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_TMN_CODE=YOUR_TMN_CODE
VNP_HASH_SECRET=YOUR_HASH_SECRET
VNP_RETURN_URL=http://localhost:5173/payment/vnpay/return

# MoMo (https://developers.momo.vn/)
# Đăng ký tài khoản sandbox: https://test-payment.momo.vn/
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REFUND_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/refund
MOMO_PARTNER_CODE=YOUR_PARTNER_CODE
MOMO_ACCESS_KEY=YOUR_ACCESS_KEY
MOMO_SECRET_KEY=YOUR_SECRET_KEY
MOMO_RETURN_URL=http://localhost:5173/payment/momo/return
MOMO_NOTIFY_URL=http://localhost:5000/api/payments/callback/momo
